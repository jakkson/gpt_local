# Ollama settings
OLLAMA_MODEL=llama3.2
OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_BASE_URL=http://localhost:11434

# Document settings
DOCUMENTS_DIR=./documents
CHROMA_DB_DIR=./chroma_db
CHUNK_SIZE=1024
CHUNK_OVERLAP=200

# Hybrid search (BM25 + embeddings, recommended)
HYBRID_ENABLED=true
HYBRID_VECTOR_CANDIDATES=20
HYBRID_BM25_CANDIDATES=20
HYBRID_FUSION_TOP_K=8
HYBRID_RRF_K=60
# Rebuild BM25 keyword index when chunk count changes by at least this much
HYBRID_BM25_REBUILD_MIN_DELTA=2000

# Outlook 365 (Azure App Registration)
# See README.md for setup instructions
OUTLOOK_CLIENT_ID=
OUTLOOK_TENANT_ID=
OUTLOOK_REDIRECT_URI=http://localhost:8400
